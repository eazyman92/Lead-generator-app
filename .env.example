APP_ENV=development

POSTGRES_DB=lead_generator
POSTGRES_USER=lead_generator_app
POSTGRES_PASSWORD=<set-postgres-password>
DATABASE_URL=postgresql+asyncpg://lead_generator_app:<set-postgres-password>@postgres:5432/lead_generator

AUTH_ACCESS_TOKEN_EXPIRE_MINUTES=15
AUTH_REFRESH_TOKEN_EXPIRE_DAYS=30
AUTH_JWT_SECRET_KEY=<set-jwt-secret-key>
AUTH_COOKIE_DOMAIN=
AUTH_COOKIE_SECURE=false
AUTH_COOKIE_SAMESITE=Lax

INTERNAL_API_TOKEN=<set-internal-api-token>
ENCRYPTION_KEY=<set-encryption-key>

BACKEND_CORS_ORIGINS=http://localhost:3000
NEXT_PUBLIC_API_BASE_URL=

BACKEND_INTERNAL_BASE_URL=http://backend:8000
WORKER_ID=worker-1
WORKER_VERSION=0.1.0
WORKER_RUN_ENABLED=true
WORKER_POLL_INTERVAL_SECONDS=2
WORKER_IDLE_BACKOFF_MAX_SECONDS=30
WORKER_BACKOFF_MULTIPLIER=2
WORKER_HEARTBEAT_INTERVAL_SECONDS=30
WORKER_MAX_CONCURRENT_JOBS=1
WORKER_DEFAULT_RETRY_DELAY_SECONDS=60
WORKER_RETRY_MAX_DELAY_SECONDS=3600
WORKER_JOB_TIMEOUT_SECONDS=300
WORKER_HTTP_TIMEOUT_SECONDS=45
WORKER_USER_AGENT=LeadGeneratorAppWorker/0.1
CONTACT_COLLECTION_PROVIDER=osm
CONTACT_COLLECTION_MAX_LIMIT=50
